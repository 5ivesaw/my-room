{
  "name": "my-room-kingdom-companion",
  "version": "1.2.1",
  "private": true,
  "description": "Secure tray presence, audience inbox, and Royal Mail companion for My Kingdom",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "build:win:installer": "electron-builder --win nsis --x64 --publish never",
    "build:win:portable": "electron-builder --win portable --x64 --publish never"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "lol.goat.kingdomcompanion",
    "productName": "Kingdom Companion",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer.js",
      "index.html",
      "styles.css",
      "firebase-config.js",
      "firebase-config.sample.js",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/kingdom-companion.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kingdom Companion",
      "artifactName": "Kingdom-Companion-Setup-${version}-${arch}.${ext}"
    },
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "removePackageScripts": true,
    "portable": {
      "artifactName": "Kingdom-Companion-Portable-${version}-${arch}.${ext}"
    }
  }
}
