rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roomDoc(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function memberDoc(roomId, uid) {
      return /databases/$(database)/documents/rooms/$(roomId)/members/$(uid);
    }

    function isMember(roomId) {
      return signedIn() && exists(memberDoc(roomId, request.auth.uid));
    }

    function isOwner(roomId) {
      return signedIn()
        && exists(roomDoc(roomId))
        && get(roomDoc(roomId)).data.createdBy == request.auth.uid;
    }

    function isSovereign() {
      return signedIn()
        && exists(/databases/$(database)/documents/kingdom/config)
        && get(/databases/$(database)/documents/kingdom/config).data.ownerUid == request.auth.uid;
    }

    function validDisplayName(name) {
      return name is string
        && name.size() >= 2
        && name.size() <= 24
        && name.matches('^[A-Za-z0-9 _.-]+$');
    }

    match /kingdom/{documentId} {
      // Presence is intentionally public: the 3D room reads it before a visitor opens chat.
      allow get: if documentId == 'presence';
      allow list: if false;
      allow create, update: if documentId == 'presence'
        && isSovereign()
        && request.resource.data.status in ['online', 'busy', 'sleeping', 'offline']
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 120
        && (!request.resource.data.keys().hasAny(['contactUid'])
          || (request.resource.data.contactUid is string && request.resource.data.contactUid.size() <= 128));
      allow delete: if false;
    }

    match /kingdom/audienceMessages/items/{messageId} {
      allow create: if signedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.publicCode == request.auth.uid
        && validDisplayName(request.resource.data.displayName)
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 900
        && request.resource.data.statusAtSubmission is string
        && request.resource.data.statusAtSubmission.size() <= 24
        && request.resource.data.createdMs is number
        && (
          request.resource.data.attachment == null
          || (
            request.resource.data.attachment is map
            && request.resource.data.attachment.name is string
            && request.resource.data.attachment.name.size() <= 80
            && request.resource.data.attachment.type is string
            && request.resource.data.attachment.type.size() <= 80
            && request.resource.data.attachment.size is number
            && request.resource.data.attachment.size <= 480000
            && request.resource.data.attachment.dataUrl is string
            && request.resource.data.attachment.dataUrl.size() <= 650000
          )
        );
      allow read, delete: if isSovereign();
      allow update: if false;
    }

    function validPublicProfile(data, uid) {
      return data.uid == uid
        && data.publicCode == uid
        && validDisplayName(data.displayName)
        && data.avatar is string
        && data.avatar.size() <= 80
        && data.lastSeenMs is number
        && (!data.keys().hasAny(['publicKey']) || data.publicKey is map);
    }

    function validMemberProfile(data, uid) {
      return data.uid == uid
        && validDisplayName(data.displayName)
        && (!data.keys().hasAny(['avatar']) || (data.avatar is string && data.avatar.size() <= 80));
    }

    match /users/{uid} {
      // Signed-in visitors need individual profile reads for friend codes.
      // Only the sovereign can list the directory for the companion's live court view.
      allow get: if signedIn();
      allow list: if isSovereign();

      allow create, update: if signedIn()
        && uid == request.auth.uid
        && validPublicProfile(request.resource.data, request.auth.uid);

      match /lordMessages/{messageId} {
        allow get, list: if signedIn()
          && (uid == request.auth.uid || isSovereign());

        allow create: if isSovereign()
          && request.resource.data.recipientUid == uid
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.createdMs is number
          && request.resource.data.expiresMs is number
          && request.resource.data.expiresAt is timestamp
          && request.resource.data.expiresMs > request.resource.data.createdMs
          && request.resource.data.expiresMs <= request.resource.data.createdMs + 86400000
          && (!request.resource.data.keys().hasAny(['contactUid'])
            || (request.resource.data.contactUid is string && request.resource.data.contactUid.size() <= 128));

        allow delete: if signedIn()
          && (uid == request.auth.uid || isSovereign());
        allow update: if false;
      }

      match /requests/{fromUid} {
        allow read, delete: if signedIn() && uid == request.auth.uid;
        allow create, update: if signedIn()
          && fromUid == request.auth.uid
          && request.resource.data.fromUid == request.auth.uid
          && validDisplayName(request.resource.data.displayName)
          && request.resource.data.avatar is string
          && request.resource.data.avatar.size() <= 80;
      }

      match /friends/{friendUid} {
        allow read, delete: if signedIn() && uid == request.auth.uid;
        // Lets the user accepting a request create both reciprocal friendship cards.
        allow create, update: if signedIn()
          && (uid == request.auth.uid || friendUid == request.auth.uid)
          && request.resource.data.uid == friendUid
          && validDisplayName(request.resource.data.displayName)
          && request.resource.data.dmRoomId is string
          && request.resource.data.dmRoomId.size() < 180
          && (!request.resource.data.keys().hasAny(['avatar']) || request.resource.data.avatar is string);
      }
    }

    match /rooms/{roomId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.label is string
        && request.resource.data.ttlHours is number
        && (
          (
            request.resource.data.inviteHash is string
            && request.resource.data.salt is string
          )
          || request.resource.data.mode == 'dm'
        );

      // Needed so someone with a room ID can fetch salt/inviteHash and verify the room secret.
      // Listing all rooms is still blocked.
      allow get: if signedIn();
      allow list: if false;

      allow update, delete: if isOwner(roomId);

      match /keys/{uid} {
        allow read: if signedIn() && uid == request.auth.uid && isMember(roomId);
        allow create, update: if isOwner(roomId)
          && get(roomDoc(roomId)).data.mode == 'dm'
          && request.resource.data.uid == uid
          && request.resource.data.encryptedSecret is string
          && request.resource.data.encryptedSecret.size() < 800;
        allow delete: if false;
      }

      match /members/{uid} {
        allow read: if isMember(roomId);

        allow create: if signedIn()
          && validMemberProfile(request.resource.data, uid)
          && (
            (
              uid == request.auth.uid
              && request.resource.data.inviteHash == get(roomDoc(roomId)).data.inviteHash
            )
            || (
              isOwner(roomId)
              && get(roomDoc(roomId)).data.mode == 'dm'
            )
          );

        allow update: if signedIn()
          && uid == request.auth.uid
          && isMember(roomId)
          && validMemberProfile(request.resource.data, request.auth.uid);

        allow delete: if signedIn() && uid == request.auth.uid;
      }

      match /messages/{messageId} {
        allow read: if isMember(roomId);

        allow create: if isMember(roomId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.type == 'text'
          && request.resource.data.iv is string
          && request.resource.data.ciphertext is string
          && request.resource.data.iv.size() < 80
          && request.resource.data.ciphertext.size() < 750000;

        allow delete: if isMember(roomId)
          && resource.data.senderId == request.auth.uid;

        allow update: if false;
      }
    }
  }
}
